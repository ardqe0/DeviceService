@inherits LayoutComponentBase
@implements IDisposable
@implements IAsyncDisposable
@using System.Text
@using System.Text.Json
@inject IJSRuntime Js

<div class="app-shell @(darkMode ? "dark" : "")">
    <header class="topbar">
        <a class="brand" href="/">DeviceService</a>
        <button type="button"
                class="mobile-menu-button @(menuOpen ? "active" : "")"
                aria-label="Menüyü aç veya kapat"
                aria-expanded="@menuOpen"
                @onclick="ToggleMenu">
            <span></span>
            <span></span>
            <span></span>
        </button>
        <nav class="nav-links @(menuOpen ? "open" : "")">
            <NavLink href="/" Match="NavLinkMatch.All" @onclick="CloseMenu">Ana Sayfa</NavLink>
            @if (Session.IsService)
            {
                <NavLink href="/musteriler" @onclick="CloseMenu">Müşteriler</NavLink>
                <NavLink href="/servis-fisleri" @onclick="CloseMenu">Servis Fişleri</NavLink>
            }
            @if (Session.IsCustomer)
            {
                <NavLink href="/musteri-paneli" @onclick="CloseMenu">Hesabım</NavLink>
            }
        </nav>
        <div class="top-actions"></div>
    </header>

    @if (!string.IsNullOrWhiteSpace(sessionWarning))
    {
        <div class="session-warning" role="status">
            <span>@sessionWarning</span>
            <button type="button" class="text-button" @onclick="DismissWarning">Tamam</button>
        </div>
    }

    <main class="page-content">@Body</main>
    <nav class="mobile-bottom-nav" aria-label="Mobil menü">
        <NavLink href="/" Match="NavLinkMatch.All"><span class="mobile-nav-icon" aria-hidden="true">⌂</span><span>Ana Sayfa</span></NavLink>
        @if (Session.IsCustomer)
        {
            <NavLink href="/musteri-paneli"><span class="mobile-nav-icon" aria-hidden="true">♙</span><span>Hesabım</span></NavLink>
        }
        @if (Session.IsService)
        {
            <NavLink href="/musteriler"><span class="mobile-nav-icon" aria-hidden="true">♙</span><span>Müşteriler</span></NavLink>
            <NavLink href="/servis-fisleri"><span class="mobile-nav-icon" aria-hidden="true">▣</span><span>Servis Fişleri</span></NavLink>
        }
    </nav>
    <button type="button"
            class="floating-theme-toggle @(darkMode ? "active" : "")"
            title="@(darkMode ? "Açık temaya geç" : "Koyu temaya geç")"
            aria-label="@(darkMode ? "Açık temaya geç" : "Koyu temaya geç")"
            @onclick="ToggleTheme">
        <span aria-hidden="true">@(darkMode ? "☀" : "☾")</span>
    </button>
</div>

@code {
    private const string RememberedSessionKey = "device-service-remembered-session";
    private bool darkMode;
    private bool menuOpen;
    private string? sessionWarning;
    private DotNetObjectReference<MainLayout>? monitorReference;

    protected override void OnInitialized() => Session.Changed += OnSessionChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            monitorReference = DotNetObjectReference.Create(this);

        await ConfigureSessionMonitorAsync();
    }

    private void OnSessionChanged(object? sender, EventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            await ConfigureSessionMonitorAsync();
            StateHasChanged();
        });
    }

    private async Task ConfigureSessionMonitorAsync()
    {
        if (monitorReference is null)
            return;

        var expiresAt = GetExpiration(Session.Token);
        if (!Session.IsAuthenticated || expiresAt is null)
        {
            sessionWarning = null;
            await Js.InvokeVoidAsync("deviceServiceSession.stop");
            return;
        }

        await Js.InvokeVoidAsync("deviceServiceSession.start", monitorReference, expiresAt.Value.ToUnixTimeSeconds(), 900, 120, 300);
    }

    [JSInvokable]
    public Task ShowSessionWarning(string reason, int remainingSeconds)
    {
        sessionWarning = reason == "inactivity"
            ? $"İşlem yapılmadığı için oturumunuz {FormatRemainingTime(remainingSeconds)} içinde kapanacak."
            : $"Oturumunuz {FormatRemainingTime(remainingSeconds)} içinde sona erecek.";
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task EndSession(string reason) => InvokeAsync(async () =>
    {
        await LogoutAsync();
    });

    private void ToggleTheme() => darkMode = !darkMode;
    private void ToggleMenu() => menuOpen = !menuOpen;
    private void CloseMenu() => menuOpen = false;
    private void DismissWarning() => sessionWarning = null;

    private async Task LogoutAsync()
    {
        Api.SetAccessToken(null);
        Session.End();
        sessionWarning = null;
        await Js.InvokeVoidAsync("localStorage.removeItem", RememberedSessionKey);
        Navigation.NavigateTo("/");
    }

    private static string FormatRemainingTime(int seconds) => seconds >= 60
        ? $"{Math.Max(1, (int)Math.Ceiling(seconds / 60d))} dakika"
        : $"{Math.Max(1, seconds)} saniye";

    private static DateTimeOffset? GetExpiration(string? token)
    {
        if (string.IsNullOrWhiteSpace(token))
            return null;

        try
        {
            var payload = token.Split('.')[1].Replace('-', '+').Replace('_', '/');
            payload = payload.PadRight(payload.Length + ((4 - payload.Length % 4) % 4), '=');
            using var document = JsonDocument.Parse(Encoding.UTF8.GetString(Convert.FromBase64String(payload)));
            return document.RootElement.TryGetProperty("exp", out var expiry)
                ? DateTimeOffset.FromUnixTimeSeconds(expiry.GetInt64())
                : null;
        }
        catch
        {
            return null;
        }
    }

    public void Dispose() => Session.Changed -= OnSessionChanged;

    public ValueTask DisposeAsync()
    {
        monitorReference?.Dispose();
        return ValueTask.CompletedTask;
    }
}
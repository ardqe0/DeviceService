@page "/"
@implements IDisposable
@using System.Text
@using System.Text.Json
@inject IJSRuntime Js

<PageTitle>Ana Sayfa</PageTitle>

<section class="page-heading">
    <div>
        <h1>Servis Takip Sistemi</h1>
        <p>Cihaz servis süreçlerini tek yerden yönetin ve takip edin.</p>
    </div>
</section>

@if (Session.IsAuthenticated)
{
    @if (Session.IsCustomer)
    {
        <CustomerTicketsPanel />
    }
    else
    {
        <section class="welcome-panel">
            <div>
                <span class="eyebrow">Oturum açık</span>
                <h2>Hoş geldiniz, @Session.User!.FullName</h2>
            </div>
            <div class="welcome-actions">
                <button class="button primary" @onclick="GoToPanel">Servis Fişlerine Git</button>
                <button class="button secondary" @onclick="OpenSecurity">Hesap Güvenliği</button>
                <button class="button secondary" @onclick="Logout">Çıkış Yap</button>
            </div>
        </section>
    }
}
else
{
    <div class="auth-grid">
        <section class="panel">
            <h2>Giriş Yap</h2>
            <label>E-posta</label>
            <input type="email" @bind="loginEmail" placeholder="ornek@email.com" autocomplete="username" />
            <label>Şifre</label>
            <input type="password" @bind="loginPassword" autocomplete="current-password" />
            <label class="remember-row">
                <input type="checkbox" @bind="rememberMe" />
                <span>Beni hatırla</span>
            </label>
            <button type="button" class="button primary full" disabled="@busy" @onclick="Login">Giriş Yap</button>
            <button type="button" class="text-button" @onclick="GoToForgotPassword">Şifremi unuttum</button>
            @if (!string.IsNullOrWhiteSpace(loginMessage))
            {
                <p class="message error">@loginMessage</p>
            }
        </section>

        <section class="panel">
            <h2>Hesap Oluştur</h2>
            <div class="form-grid">
                <div><label>Ad soyad</label><input @bind="register.FullName" autocomplete="name" /></div>
                <div><label>Telefon</label><input type="tel" @bind="register.PhoneNumber" autocomplete="tel" /></div>
                <div><label>E-posta</label><input type="email" @bind="register.Email" autocomplete="email" /></div>
                <div><label>Şifre</label><input type="password" @bind="register.Password" placeholder="En az 8 karakter" autocomplete="new-password" /></div>
            </div>
            <label class="switch-row">
                <input type="checkbox" @bind="register.IsService" />
                <span>Servis hesabı oluştur</span>
            </label>
            @if (register.IsService)
            {
                <div class="form-grid business-fields">
                    <div><label>İşyeri unvanı</label><input @bind="register.BusinessName" /></div>
                    <div><label>Vergi kimlik numarası</label><input @bind="register.TaxNumber" /></div>
                    <div><label>Yetkili kişi</label><input @bind="register.ContactName" /></div>
                    <div><label>Servis kayıt kodu</label><input type="password" @bind="register.ServiceRegistrationCode" autocomplete="off" /></div>
                    <div class="span-2"><label>İşyeri adresi</label><textarea @bind="register.BusinessAddress"></textarea></div>
                </div>
            }
            <button type="button" class="button teal full" disabled="@busy" @onclick="Register">Hesap Oluştur</button>
            @if (!string.IsNullOrWhiteSpace(registerMessage))
            {
                <p class="message error">@registerMessage</p>
            }
        </section>
    </div>
}

@if (securityOpen)
{
    <AccountSecurityModal OnClose="CloseSecurity" />
}

@code {
    private const string RememberedSessionKey = "device-service-remembered-session";
    private string loginEmail = string.Empty;
    private string loginPassword = string.Empty;
    private string loginMessage = string.Empty;
    private string registerMessage = string.Empty;
    private bool rememberMe;
    private bool busy;
    private bool securityOpen;
    private bool deviceConfigured;
    private RegisterAccountRequest register = new();

    protected override void OnInitialized()
    {
        Session.Changed += OnSessionChanged;
    }

    private void OnSessionChanged(object? sender, EventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await ConfigureDeviceAsync();
        if (Session.IsAuthenticated)
            return;

        try
        {
            var storedSession = await Js.InvokeAsync<string?>("localStorage.getItem", RememberedSessionKey);
            var response = string.IsNullOrWhiteSpace(storedSession)
                ? null
                : JsonSerializer.Deserialize<AuthResponse>(storedSession);

            if (response is null || string.IsNullOrWhiteSpace(response.Token) || IsExpired(response.Token))
            {
                await Js.InvokeVoidAsync("localStorage.removeItem", RememberedSessionKey);
                return;
            }

            Api.SetAccessToken(response.Token);
            Session.Start(response);
            GoToPanel();
        }
        catch (JSException)
        {
            // Yerel depolama kullanılamıyorsa geçici oturumla devam edilir.
        }
    }
    private async Task Login()
    {
        busy = true;
        loginMessage = string.Empty;
        var response = await Api.LoginAsync(loginEmail.Trim(), loginPassword);
        busy = false;

        if (response is null)
        {
            loginMessage = Api.LastErrorMessage;
            return;
        }

        Api.SetAccessToken(response.Token);
        Session.Start(response);
        await UpdateRememberedSessionAsync(response, rememberMe);
        GoToPanel();
    }

    private async Task Register()
    {
        busy = true;
        registerMessage = string.Empty;
        var response = await Api.RegisterAsync(register);
        busy = false;

        if (response is null)
        {
            registerMessage = Api.LastErrorMessage;
            return;
        }

        Api.SetAccessToken(response.Token);
        Session.Start(response);
        await UpdateRememberedSessionAsync(response, false);
        GoToPanel();
    }

    private async Task ConfigureDeviceAsync()
    {
        if (deviceConfigured)
            return;

        try
        {
            var device = await Js.InvokeAsync<ClientDevice>("deviceServiceSession.getOrCreateDevice");
            Api.SetDeviceInfo(device.Id, device.Name);
            deviceConfigured = true;
        }
        catch (JSException)
        {
            // Cihaz bilgisi alınamıyorsa API güvenli sunucu tarafı parmak iziyle devam eder.
        }
    }

    private void GoToForgotPassword() => Navigation.NavigateTo("/sifremi-unuttum");

    private sealed class ClientDevice
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
    }
    private void GoToPanel() => Navigation.NavigateTo(Session.IsService ? "/servis-fisleri" : "/");
    private void OpenSecurity() => securityOpen = true;
    private void CloseSecurity() => securityOpen = false;

    private async Task Logout()
    {
        Api.SetAccessToken(null);
        Session.End();
        await Js.InvokeVoidAsync("localStorage.removeItem", RememberedSessionKey);
        Navigation.NavigateTo("/");
    }

    private Task UpdateRememberedSessionAsync(AuthResponse response, bool shouldRemember) => shouldRemember
        ? Js.InvokeVoidAsync("localStorage.setItem", RememberedSessionKey, JsonSerializer.Serialize(response)).AsTask()
        : Js.InvokeVoidAsync("localStorage.removeItem", RememberedSessionKey).AsTask();

    private static bool IsExpired(string token)
    {
        try
        {
            var payload = token.Split('.')[1].Replace('-', '+').Replace('_', '/');
            payload = payload.PadRight(payload.Length + ((4 - payload.Length % 4) % 4), '=');
            using var document = JsonDocument.Parse(Encoding.UTF8.GetString(Convert.FromBase64String(payload)));
            return !document.RootElement.TryGetProperty("sv", out var sessionVersion)
                || string.IsNullOrWhiteSpace(sessionVersion.GetString())
                || !document.RootElement.TryGetProperty("exp", out var expiry)
                || DateTimeOffset.FromUnixTimeSeconds(expiry.GetInt64()) <= DateTimeOffset.UtcNow;
        }
        catch
        {
            return true;
        }
    }
    public void Dispose()
    {
        Session.Changed -= OnSessionChanged;
    }
}

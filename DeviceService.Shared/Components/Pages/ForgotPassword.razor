@page "/sifremi-unuttum"

<PageTitle>Şifremi Unuttum</PageTitle>

<section class="page-heading">
    <div>
        <h1>Şifremi Unuttum</h1>
        <p>Hesabınıza bağlı e-posta adresine şifre sıfırlama bağlantısı göndeririz.</p>
    </div>
</section>

<section class="panel narrow-panel">
    <label>E-posta</label>
    <input type="email" @bind="email" autocomplete="email" placeholder="ornek@email.com" />
    <button type="button" class="button primary full" disabled="@busy" @onclick="SendResetLink">Bağlantı Gönder</button>
    @if (!string.IsNullOrWhiteSpace(message))
    {
        <p class="message @(sent ? "success" : "error")">@message</p>
    }
</section>

@code {
    private string email = string.Empty;
    private string message = string.Empty;
    private bool sent;
    private bool busy;

    private async Task SendResetLink()
    {
        message = string.Empty;
        sent = false;
        busy = true;
        var succeeded = await Api.ForgotPasswordAsync(email.Trim());
        busy = false;
        sent = succeeded;
        message = succeeded
            ? "E-posta adresi kayıtlıysa şifre sıfırlama bağlantısı gönderildi."
            : Api.LastErrorMessage;
    }
}
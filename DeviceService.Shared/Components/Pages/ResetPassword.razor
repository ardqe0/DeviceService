@page "/sifre-sifirla"
@using Microsoft.AspNetCore.Components

<PageTitle>Şifre Sıfırla</PageTitle>

<section class="page-heading">
    <div>
        <h1>Yeni Şifre Belirle</h1>
        <p>Güçlü ve daha önce kullanmadığınız bir şifre oluşturun.</p>
    </div>
</section>

<section class="panel narrow-panel">
    @if (string.IsNullOrWhiteSpace(token))
    {
        <p class="message error">Şifre sıfırlama bağlantısı geçersiz.</p>
    }
    else
    {
        <label>Yeni şifre</label>
        <input type="password" @bind="newPassword" autocomplete="new-password" placeholder="En az 8 karakter, harf ve rakam" />
        <label>Yeni şifre tekrarı</label>
        <input type="password" @bind="confirmPassword" autocomplete="new-password" />
        <button type="button" class="button primary full" disabled="@busy" @onclick="SaveNewPassword">Şifreyi Kaydet</button>
        @if (!string.IsNullOrWhiteSpace(message))
        {
            <p class="message @(succeeded ? "success" : "error")">@message</p>
        }
    }
</section>

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private string? token;
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;
    private string message = string.Empty;
    private bool succeeded;
    private bool busy;

    protected override void OnParametersSet() => token = Token;

    private async Task SaveNewPassword()
    {
        message = string.Empty;
        succeeded = false;
        if (newPassword != confirmPassword)
        {
            message = "Yeni şifre ve tekrarı aynı olmalıdır.";
            return;
        }

        busy = true;
        var resetSucceeded = await Api.ResetPasswordAsync(token!, newPassword);
        busy = false;
        succeeded = resetSucceeded;
        message = resetSucceeded
            ? "Şifreniz değiştirildi. Giriş yapmak için ana sayfaya yönlendiriliyorsunuz."
            : Api.LastErrorMessage;

        if (resetSucceeded)
            Navigation.NavigateTo("/", replace: true);
    }
}